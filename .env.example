# ============================================================
# Close-Pro — variables d'environnement
# Copier en .env.local (front) et configurer sur Vercel (backend).
# Ne JAMAIS committer les vraies cles.
# ============================================================

# --- Front (PWA) : prefixe VITE_ obligatoire, expose au navigateur ---
# Cle ANON uniquement (publique, protegee par RLS). Jamais la service_role ici.
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Backend (Vercel serverless : /api/*) : secrets, jamais exposes ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...

# Secret partage entre Vercel et le Google Apps Script (ingestion)
INGEST_SECRET=choisir-une-longue-chaine-aleatoire

# Telegram (alertes proprietaire). Bot cree via @BotFather.
TELEGRAM_BOT_TOKEN=123456789:AA...
# chat_id : ouvrir https://api.telegram.org/bot<token>/getUpdates apres avoir
# ecrit /start au bot, puis lire result[0].message.chat.id
TELEGRAM_CHAT_ID=123456789
